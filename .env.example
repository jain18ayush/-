# Server-side only. Written by `npx @insforge/cli ai setup` into .env.local.
# Used by the Electron main process for the LLM "understanding" layer.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional overrides
# OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.5

# Note: the Deepgram API key is NOT stored here. It is entered in the app's
# Settings panel and saved to the local electron-store config on your machine.
